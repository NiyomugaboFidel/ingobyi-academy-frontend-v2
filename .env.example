# Copy to .env.local for local development:
#   cp .env.example .env.local

# NestJS API (required in production — set in Vercel → Settings → Environment Variables)
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# WebSocket base URL (optional; defaults from API URL without /api)
NEXT_PUBLIC_WS_URL=http://localhost:3001

# Show demo login hints on /login (use false in production)
NEXT_PUBLIC_SHOW_DEMO_CREDENTIALS=true
